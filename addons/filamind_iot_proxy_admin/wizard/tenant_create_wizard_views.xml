<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_proxy_tenant_create_wizard_form" model="ir.ui.view">
        <field name="name">iot.proxy.tenant.create.wizard.form</field>
        <field name="model">iot.proxy.tenant.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Proxy Tenant">
                <group>
                    <field name="name"/>
                    <field name="plan"/>
                    <field name="box_quota"/>
                    <field name="contact_email"/>
                    <field name="license_key"/>
                    <field name="license_expires"/>
                </group>
                <footer>
                    <button name="action_create" type="object"
                            string="Create" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_iot_proxy_tenant_create_wizard" model="ir.actions.act_window">
        <field name="name">Create Tenant on Proxy</field>
        <field name="res_model">iot.proxy.tenant.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
