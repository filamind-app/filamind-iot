<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_proxy_tenant_list" model="ir.ui.view">
        <field name="name">iot.proxy.tenant.list</field>
        <field name="model">iot.proxy.tenant</field>
        <field name="arch" type="xml">
            <list string="Proxy Tenants">
                <field name="name"/>
                <field name="plan"/>
                <field name="box_quota"/>
                <field name="contact_email"/>
                <field name="license_expires"/>
                <field name="remote_created_at"/>
                <field name="proxy_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_iot_proxy_tenant_form" model="ir.ui.view">
        <field name="name">iot.proxy.tenant.form</field>
        <field name="model">iot.proxy.tenant</field>
        <field name="arch" type="xml">
            <form string="Proxy Tenant" create="false" edit="false">
                <header>
                    <button name="action_delete_remote" type="object"
                            string="Delete on Proxy"
                            class="btn-danger"
                            confirm="Delete this tenant on the proxy? This is irreversible and only succeeds if no boxes are attached."/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="remote_id" string="Tenant ID"/>
                            <field name="plan"/>
                            <field name="box_quota"/>
                        </group>
                        <group>
                            <field name="contact_email"/>
                            <field name="license_key"/>
                            <field name="license_expires"/>
                            <field name="remote_created_at"/>
                            <field name="proxy_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_proxy_tenant" model="ir.actions.act_window">
        <field name="name">Tenants</field>
        <field name="res_model">iot.proxy.tenant</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
