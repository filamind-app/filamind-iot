<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_workcenter_form_iot" model="ir.ui.view">
        <field name="name">mrp.workcenter.form.iot</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="IoT Devices (filamind)" name="filamind_iot_group">
                    <group>
                        <field name="iot_box_id"
                               options="{'no_create': True, 'no_quick_create': True}"/>
                        <field name="iot_label_printer_id"
                               readonly="not iot_box_id"
                               options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="iot_caliper_id"
                               readonly="not iot_box_id"
                               options="{'no_create': True}"/>
                        <field name="iot_scanner_id"
                               readonly="not iot_box_id"
                               options="{'no_create': True}"/>
                    </group>
                </group>
                <group string="IoT Quick Tests" invisible="not iot_box_id">
                    <div colspan="2" class="d-flex flex-wrap gap-2">
                        <button name="action_iot_test_caliper"
                                type="object"
                                string="Read Caliper"
                                class="btn btn-secondary"
                                icon="fa-tachometer"
                                invisible="not iot_caliper_id"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
