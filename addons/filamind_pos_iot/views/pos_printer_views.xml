<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_printer_form_iot" model="ir.ui.view">
        <field name="name">pos.printer.form.iot</field>
        <field name="model">pos.printer</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_printer_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="IoT (filamind)" name="filamind_iot_group">
                    <field name="iot_device_id"
                           options="{'no_create': True}"
                           help="When set, kitchen tickets dispatch via the IoT Box instead of over IPP."/>
                    <field name="iot_use_lna"/>
                    <button name="action_iot_test_print"
                            type="object"
                            string="Test Print via IoT"
                            class="btn btn-secondary"
                            icon="fa-print"
                            invisible="not iot_device_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
