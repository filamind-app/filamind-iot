# Caddyfile bundled with the docker-compose.yml stack.
# Mirrors the recipe from docs/REVERSE_PROXY_PLATFORMS.md.
#
# By default Caddy auto-provisions Let's Encrypt for any
# real hostname; for local dev hit it on http://localhost:80
# (we disable the HTTPS auto-redirect via auto_https off).

{
    auto_https off
    admin off
}

:80 {
    encode gzip

    # WebSocket — must hit the gevent port (8072), not the main one.
    @ws {
        path /websocket
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    reverse_proxy @ws odoo:8072

    # Everything else — long-poll, short-poll, normal HTTP — to 8069
    reverse_proxy odoo:8069 {
        flush_interval -1
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP         {remote}
    }
}
